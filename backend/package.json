    "dotenv": "^16.0.3",
    "express": "4.18.2",
    "jsonwebtoken": "^9.0.0",
    "moment": "^2.29.4",
    "nodemailer": "^6.9.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}